rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone can read, only own doc can be written
    // Prevent non-admins from setting isAdmin on themselves
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.isAdmin == false;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (request.resource.data.isAdmin == resource.data.isAdmin
            || resource.data.isAdmin == true);
    }

    // Ballots: doc ID = user UID
    // Read own always, read others after ceremony started
    // Write own only when not locked
    match /ballots/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || (exists(/databases/$(database)/documents/config/ceremony)
            && get(/databases/$(database)/documents/config/ceremony).data.ceremonyStarted == true)
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!exists(/databases/$(database)/documents/config/ceremony)
            || get(/databases/$(database)/documents/config/ceremony).data.isLocked != true);
    }

    // Config: public read, admin write only
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Groups: public authenticated read for discovery, member/creator update
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Existing members/creator can update anything
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.createdBy
            || request.auth.uid in resource.data.members);
      // New member can self-join via link (arrayUnion to members)
      allow update: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && !(request.auth.uid in resource.data.members);
      // Non-member can request to join (only adds self to pendingMembers)
      allow update: if request.auth != null
        && !(request.auth.uid in resource.data.members)
        && !(request.auth.uid in resource.data.get('pendingMembers', []))
        && request.auth.uid in request.resource.data.get('pendingMembers', [])
        && request.resource.data.members == resource.data.members
        && request.resource.data.name == resource.data.name
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.joinCode == resource.data.joinCode;
    }

    // Join codes: O(1) lookup by code, maps to groupId
    match /joinCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
